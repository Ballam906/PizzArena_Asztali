<Window x:Class="PizzArena_AdminPanel.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PizzAréna - Adminisztrációs Központ" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="14" FontWeight="Medium" Margin="10,8"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="BorderThickness" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" Margin="0,2">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FEF2F2"/>
                                <Setter Property="Foreground" Value="#DC2626"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F3F4F6"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FEF2F2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Background="#F9FAFB" Grid.ColumnSpan="2">
                    <Border Background="#DC2626" Padding="20">
                        <TextBlock Text="PizzAréna" Foreground="White" FontSize="20" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ADMINISZTRÁCIÓ" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF" Margin="20,20,0,10"/>
                </StackPanel>

                <Border Grid.Column="2" VerticalAlignment="Top" Height="59" Background="White" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="-0.057"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <TextBlock Text="PizzAréna Rendszerfelügyelet v1.1 - Integrált Vezérlő" VerticalAlignment="Center" Margin="25,0" Foreground="#9CA3AF" FontStyle="Italic"/>
                </Border>

                <TabControl x:Name="MainTabControl" Grid.ColumnSpan="3" TabStripPlacement="Left" BorderThickness="0" Background="Transparent" Margin="0,110,0,0">

                    <TabItem Header="Séf ajánlatok">
                        <Grid Margin="40,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Séf ajánlatok" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                            <DataGrid x:Name="ChefSpecialGrid" Grid.Row="1" SelectionChanged="ChefSpecialGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                                    <DataGridTextColumn Header="Termék ID" Binding="{Binding ProductId}" Width="150"/>
                                    <DataGridTextColumn Header="Megjegyzés" Binding="{Binding CustomNote}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="2" Margin="0,20,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <TextBox x:Name="ChefSpecialProductIdTextBox" Width="150" Tag="ProductId"/>
                                    <TextBox x:Name="ChefSpecialCustomNoteTextBox" Width="250" Tag="CustomNote"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Reload" Click="ChefSpecialReload_Click" Background="#4B5563"/>
                                    <Button Content="Add" Click="ChefSpecialAdd_Click" Background="#059669"/>
                                    <Button Content="Update" Click="ChefSpecialUpdate_Click" Background="#2563EB"/>
                                    <Button Content="Delete" Click="ChefSpecialtDelete_Click" Background="#DC2626"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Fő beállítások">
                        <Grid Margin="40,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Globális Beállítások" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                            <StackPanel Grid.Row="1" MaxWidth="400" HorizontalAlignment="Left">
                                <Label Content="Kapcsolat tartási email cím:"/>
                                <TextBox x:Name="GlobalContactEmailTextBox" Margin="0,0,0,15"/>
                                <Label Content="Általános szállítási idő:"/>
                                <TextBox x:Name="GlobalDeliveryTextBox" Margin="0,0,0,15"/>
                                <Label Content="Facebook URL:"/>
                                <TextBox x:Name="GlobalFacebookTextBox" Margin="0,0,0,15"/>
                                <Label Content="Instagram URL:"/>
                                <TextBox x:Name="GlobalInstagramTextBox" Margin="0,0,0,15"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Reload" Click="GlobalReload_Click" Background="#4B5563"/>
                                <Button Content="Update" Click="GlobalUpdate_Click" Background="#2563EB"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Rendelések">
                        <Grid Margin="40,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Rendelések Éttermek Szerint" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DataGrid x:Name="OrderRestaurantGrid" Grid.Row="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Étterem" Binding="{Binding name}" Width="200"/>
                                    <DataGridTextColumn Header="Cím" Binding="{Binding address}" Width="*"/>
                                    <DataGridTemplateColumn Header="Művelet" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Rendelések" Click="OpenRestaurantOrders_Click" Tag="{Binding}" Background="#2563EB" Height="24" FontSize="11"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Éttermek">
                        <Grid Margin="40,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Éttermek Kezelése" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DataGrid x:Name="RestaurantGrid" Grid.Row="1" SelectionChanged="RestaurantGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Név" Binding="{Binding name}" Width="150"/>
                                    <DataGridTextColumn Header="Cím" Binding="{Binding address}" Width="150"/>
                                    <DataGridTextColumn Header="Telefon" Binding="{Binding contactPhone}" Width="120"/>
                                    <DataGridTextColumn Header="Nyitvatartás" Binding="{Binding openingHours}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                                <WrapPanel HorizontalAlignment="Center">
                                    <TextBox x:Name="RestaurantNameTextBox" Width="100" Tag="Név"/>
                                    <TextBox x:Name="RestaurantDescriptionTextBox" Width="100" Tag="Leírás"/>
                                    <TextBox x:Name="RestaurantimageUrlTextBox" Width="100" Tag="Kép URL"/>
                                    <TextBox x:Name="RestaurantopeningHoursTextBox" Width="100" Tag="Nyitvatartás"/>
                                    <TextBox x:Name="RestaurantaddressTextBox" Width="100" Tag="Cím"/>
                                    <TextBox x:Name="RestaurantcontactphoneTextBox" Width="100" Tag="Telefon"/>
                                </WrapPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <Button Content="Reload" Click="RestaurantReload_Click" Background="#4B5563"/>
                                    <Button Content="Add" Click="RestaurantAdd_Click" Background="#059669"/>
                                    <Button Content="Update" Click="RestaurantUpdate_Click" Background="#2563EB"/>
                                    <Button Content="Delete" Click="RestaurantDelete_Click" Background="#DC2626"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Felhasználók">
                        <Grid Margin="40,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Felhasználók" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                <Label Content="Keresés:" VerticalAlignment="Center"/>
                                <TextBox x:Name="SearchUserTextBox" Width="200" TextChanged="SearchUserTextBox_TextChanged"/>
                            </StackPanel>
                            <DataGrid x:Name="UsersGrid" Grid.Row="2" SelectionChanged="UsersGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="200"/>
                                    <DataGridTextColumn Header="Felhasználónév" Binding="{Binding userName}" Width="150"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding email}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="3" Margin="0,15,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <TextBox x:Name="UsernameTextBox" Width="120" />
                                    <TextBox x:Name="UserEmailTextbox" Width="150" />
                                    <TextBox x:Name="UserPasswordTextBox" Width="120" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Reload" Click="UserReload_Click" Background="#4B5563"/>
                                    <Button Content="Add" Click="UserAdd_Click" Background="#059669"/>
                                    <Button Content="Delete" Click="UserDelete_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Termékek">
                        <Grid Margin="40,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Termékek Kezelése" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                <Label Content="Keresés:" VerticalAlignment="Center"/>
                                <TextBox x:Name="SearchProductTextBox" Width="200" TextChanged="SearchProductTextBox_TextChanged"/>
                            </StackPanel>
                            <DataGrid x:Name="ProductGrid" Grid.Row="2" SelectionChanged="ProductGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="120"/>
                                    <DataGridTextColumn Header="Ár" Binding="{Binding Price}" Width="80"/>
                                    <DataGridTextColumn Header="Elérhető" Binding="{Binding IsAvailable}" Width="70"/>
                                    <DataGridTextColumn Header="Kategória" Binding="{Binding CategoryId}" Width="80"/>
                                    <DataGridTextColumn Header="Leírás" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="3" Margin="0,15,0,0">
                                <WrapPanel HorizontalAlignment="Center">
                                    <TextBox x:Name="ProductNameTextBox" Width="110" />
                                    <TextBox x:Name="ProductDescriptionTextBox" Width="110" />
                                    <TextBox x:Name="ProductPriceTextBox" Width="70" />
                                    <TextBox x:Name="ProductIsAvailableTextBox" Width="70" />
                                    <TextBox x:Name="ProductImageUrlTextBox" Width="110" />
                                    <TextBox x:Name="ProductCategoryIdTextBox" Width="70" />
                                </WrapPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <Button Content="Reload" Click="ProductReload_Click" Background="#4B5563"/>
                                    <Button Content="Add" Click="ProductAdd_Click" Background="#059669"/>
                                    <Button Content="Update" Click="ProductyUpdate_Click" Background="#2563EB"/>
                                    <Button Content="Delete" Click="ProductDelete_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Kategóriák">
                        <Grid Margin="40,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Kategóriák" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DataGrid x:Name="CategoryGrid" Grid.Row="1" SelectionChanged="CategoryGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                                    <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="2" Margin="0,20,0,0">
                                <TextBox x:Name="CategoryNameTextBox" Width="300" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Reload" Click="CategoryReload_Click" Background="#4B5563"/>
                                    <Button Content="Add" Click="CategoryAdd_Click" Background="#059669"/>
                                    <Button Content="Update" Click="CategoryUpdate_Click" Background="#2563EB"/>
                                    <Button Content="Delete" Click="CategoryDelete_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>