<Window x:Class="PizzArena_AdminPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PizzAréna - Bejelentkezés" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="LoginCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
        </Style>

        <Style TargetType="Control" x:Key="InputStyle">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="PasswordBox" BasedOn="{StaticResource InputStyle}">
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#DC2626"/>

        <Border Grid.RowSpan="2" Style="{StaticResource LoginCard}" Width="320">
            <StackPanel>
                <TextBlock Text="PizzAréna" 
                           FontSize="28" 
                           FontWeight="ExtraBold" 
                           Foreground="#DC2626" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,5"/>
                <TextBlock Text="Adminisztrátori belépés" 
                           FontSize="14" 
                           Foreground="#6B7280" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,25"/>

                <Label Content="Felhasználónév" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="tbUsername" />

                <Label Content="Jelszó" Style="{StaticResource InputLabel}"/>
                <PasswordBox x:Name="pbPassword" />

                <Button Content="Bejelentkezés" 
                        Click="Button_Click"
                        Background="#DC2626" 
                        Foreground="White" 
                        Height="45" 
                        Margin="0,30,0,10" 
                        FontWeight="Bold" 
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock x:Name="lError" 
                           Text="" 
                           Foreground="#EF4444" 
                           FontSize="12" 
                           TextAlignment="Center" 
                           TextWrapping="Wrap"
                           Margin="0,5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>