<Window x:Class="PizzArena_AdminPanel.RestaurantOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rendelések Kezelése" Height="650" Width="1150" 
        WindowStartupLocation="CenterOwner" Background="#F9FAFB">

    <Window.Resources>
        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Red"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="Wheat"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="Red" FontWeight="Bold" Margin="5,0"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="RENDELÉSEK LISTÁJA" Grid.Column="0">
            <DockPanel>
                <Button DockPanel.Dock="Top" Content="Lista Frissítése" 
                        Click="ReloadOrders_Click" Style="{StaticResource RedButtonStyle}" 
                        Background="Red" Margin="0,0,0,10"/>

                <DataGrid x:Name="OrdersGrid" SelectionChanged="OrdersGrid_SelectionChanged" 
                          AutoGenerateColumns="False" IsReadOnly="True"
                          RowBackground="White" AlternatingRowBackground="#FEF2F2"
                          BorderBrush="#FECACA" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#FEE2E2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                        <DataGridTextColumn Header="Vevő Neve" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="Város" Binding="{Binding City}" Width="80"/>
                        <DataGridTemplateColumn Header="Státusz" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#FEE2E2" CornerRadius="4" Padding="4,2">
                                        <TextBlock Text="{Binding Status}" Foreground="Red" 
                                                   HorizontalAlignment="Center" FontWeight="Medium"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <GroupBox Header="RENDELÉS RÉSZLETEI" Grid.Column="1" Margin="10,5,5,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="Red" CornerRadius="5" Padding="15,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="CustomerInfoLabel" FontSize="16" FontWeight="Bold" 
                                   Text="Válasszon rendelést!" Foreground="White"/>
                        <TextBlock x:Name="AddressLabel" FontSize="12" Foreground="#FCA5A5" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="OrderItemsGrid" Grid.Row="1" AutoGenerateColumns="False" 
                          IsReadOnly="True" BorderBrush="#FECACA" RowBackground="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Termék ID" Binding="{Binding Item_Id}" Width="80"/>
                        <DataGridTextColumn Header="Mennyiség" Binding="{Binding Piece}" Width="100"/>
                        <DataGridTextColumn Header="Egységár" Binding="{Binding ItemPrice, StringFormat={}{0} Ft}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" Background="#F3F4F6" Margin="0,15,0,0" Padding="10" CornerRadius="5">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <TextBlock Text="Új állapot:" VerticalAlignment="Center" 
                                       FontWeight="SemiBold" Foreground="#374151" Margin="0,0,10,0"/>
                            <ComboBox x:Name="StatusComboBox" Width="160" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Függőben" Tag="1"/>
                                <ComboBoxItem Content="Kiszállítás alatt" Tag="2"/>
                                <ComboBoxItem Content="Szállítva" Tag="3"/>
                                <ComboBoxItem Content="Törölve" Tag="4"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Rendelés Törlése" Click="DeleteOrder_Click" 
                                    Style="{StaticResource RedButtonStyle}" Background="Red" 
                                    Width="130" Margin="0,0,10,0"/>
                            <Button Content="Állapot Mentése" Click="UpdateStatus_Click" 
                                    Style="{StaticResource RedButtonStyle}" Background="Red" 
                                    Width="130"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </GroupBox>
    </Grid>
</Window>